#!/bin/bash
# set mochios wallpaper
# usage: mochi-wallpaper [light|dark]

MODE="${1:-light}"
WALLDIR="/usr/share/wallpapers/mochios/contents/images"

if [ "$MODE" = "dark" ]; then
  WALL="${WALLDIR}/1920x1080-dark.png"
else
  WALL="${WALLDIR}/1920x1080.png"
fi

if [ -f "$WALL" ]; then
  pkexec plasma-apply-wallpaperimage "$WALL" 2>/dev/null || \
    plasma-apply-wallpaperimage "$WALL" 2>/dev/null || true
fi
