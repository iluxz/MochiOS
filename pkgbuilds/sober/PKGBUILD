# Maintainer: mochios team
pkgname=sober
pkgver=1.0.0
pkgrel=2
pkgdesc="Roblox on Linux - experimental interoperability layer (flatpak wrapper)"
arch=('any')
url="https://sober.vinegarhq.org"
license=('custom:proprietary')
depends=('flatpak')
source=("sober-$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
  cd "$srcdir"
  install -Dm755 sober-wrapper.sh "$pkgdir/usr/bin/sober"
}
