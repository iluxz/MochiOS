# Maintainer: mochios team
pkgname=sober
pkgver=1.0.0
pkgrel=2
pkgdesc="Roblox on Linux - experimental interoperability layer (flatpak wrapper)"
arch=('any')
url="https://sober.vinegarhq.org"
license=('custom:proprietary')
depends=('flatpak')
source=()
sha256sums=()

package() {
  install -Dm755 /dev/stdin "$pkgdir/usr/bin/sober" <<'WRAPPER'
#!/bin/bash
exec flatpak run org.vinegarhq.Sober "$@"
WRAPPER
}
