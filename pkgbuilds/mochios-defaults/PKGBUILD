# Maintainer: mochios team
pkgname=mochios-defaults
pkgver=0.1.0
pkgrel=1
pkgdesc="mochios default system configuration files"
arch=('any')
url="https://mochios.dev"
license=('GPL3')
depends=('zsh' 'sudo' 'btrfs-progs')
source=("mochios-defaults-$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
  cd "$srcdir"
  install -Dm644 mochios-release "$pkgdir/etc/mochios-release"
  echo "$pkgver-$pkgrel" > "$pkgdir/etc/mochios-defaults-version"
}
