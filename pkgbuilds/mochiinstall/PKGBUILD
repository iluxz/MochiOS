# Maintainer: mochios team
pkgname=mochiinstall
pkgver=0.1.0
pkgrel=6
pkgdesc="MochiOS TUI installer"
arch=("any")
url="https://mochios.dev"
license=("GPL3")
depends=("python" "python-urwid")
source=("mochiinstall-$pkgver.tar.gz")
sha256sums=("SKIP")

package() {
  cd "$srcdir"
  install -Dm755 mochiinstall_wrapper "$pkgdir/usr/bin/mochiinstall"
  install -Dm755 installer.py "$pkgdir/usr/lib/mochiinstall/installer.py"
  install -Dm755 mochiinstall_app.py "$pkgdir/usr/lib/mochiinstall/mochiinstall_app.py"
  install -Dm644 mochi_ascii.py "$pkgdir/usr/lib/mochiinstall/mochi_ascii.py"
}
