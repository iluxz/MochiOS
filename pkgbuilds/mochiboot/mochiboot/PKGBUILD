# Maintainer: mochios team <mochios@proton.me>
# AUR: mochiboot - a modern bootloader forked from limine
# Source builds from github; installs mochiboot to /usr/share/mochiboot

pkgname=mochiboot
pkgver=12.5.0
pkgrel=1
pkgdesc="A modern, secure bootloader forked from limine with mochios enhancements (boot counter, snapshot picker)"
arch=('x86_64')
url="https://github.com/iluxz/mochiboot"
license=('BSD-2-Clause')
depends=('gcc-libs' 'glibc' 'btrfs-progs')
makedepends=('gcc' 'make' 'nasm' 'autoconf' 'automake' 'gnu-which' 'mtools')
source=("git+https://github.com/iluxz/mochiboot.git#branch=v12.x")
sha256sums=('SKIP')

build() {
  cd "$srcdir/mochiboot"
  ./bootstrap
  ./configure --enable-grub --enable-bios --enable-uefi-x86-64
  make
}

package() {
  cd "$srcdir/mochiboot"
  make install DESTDIR="$pkgdir"

  # rename binary to mochiboot
  if [[ -f "$pkgdir/usr/bin/limine" ]]; then
    mv "$pkgdir/usr/bin/limine" "$pkgdir/usr/bin/mochiboot"
  fi

  # rename man pages
  if [[ -f "$pkgdir/usr/share/man/man1/limine.1" ]]; then
    mv "$pkgdir/usr/share/man/man1/limine.1" "$pkgdir/usr/share/man/man1/mochiboot.1"
  fi

  # install default config
  install -dm755 "$pkgdir/usr/share/mochiboot"
  install -dm755 "$pkgdir/boot/mochiboot"

  # provide a cat(1)-able sample config
  cat > "$pkgdir/usr/share/mochiboot/mochiboot.conf" << 'CONFEOF'
# mochiboot — boot menu for mochios
# Copy this to /boot/mochiboot/mochiboot.conf and edit
TIMEOUT=5
VERBOSE=no
GRAPHICS=yes
INTERFACE_BRANDING=MochiBoot
INTERFACE_BRANDING_COLOUR=00aaaa
TERM_BACKGROUND=00101a80
TERM_FOREGROUND=cdd6f4
MOCHIBOOT_RECOVERY_ENTRY=MOCHIOS (recovery mode)

:DEFAULT
    PROTOCOL=linux
    KERNEL_PATH=boot:///vmlinuz-linux
    CMDLINE=root=UUID=%ROOT_UUID% rw quiet loglevel=3

:MOCHIOS (recovery mode)
    PROTOCOL=linux
    KERNEL_PATH=boot:///vmlinuz-linux
    CMDLINE=root=UUID=%ROOT_UUID% rw quiet loglevel=3 mochi.recovery

:FALLBACK
    PROTOCOL=linux
    KERNEL_PATH=boot:///vmlinuz-linux
    CMDLINE=root=UUID=%ROOT_UUID% rw quiet loglevel=3
CONFEOF

  # also install BOOTX64.EFI to share
  if [[ -f "$pkgdir/usr/share/limine/BOOTX64.EFI" ]]; then
    cp "$pkgdir/usr/share/limine/BOOTX64.EFI" "$pkgdir/usr/share/mochiboot/BOOTX64.EFI"
  fi
  if [[ -f "$pkgdir/usr/share/limine/limine-bios.sys" ]]; then
    cp "$pkgdir/usr/share/limine/limine-bios.sys" "$pkgdir/usr/share/mochiboot/limine-bios.sys"
  fi
}
