#!/bin/bash
# mochi-snapshot - btrfs snapshot management for mochiboot
# list, select, and boot from btrfs snapshots

set -e

ROOT_DEV=""
BOOT_DIR="/boot/mochiboot"

find_root() {
    for arg in $(cat /proc/cmdline 2>/dev/null || echo ""); do
        case "$arg" in
            root=UUID=*)
                local uuid="${arg#root=UUID=}"
                ROOT_DEV=$(blkid -U "$uuid" 2>/dev/null)
                ;;
            root=/dev/*)
                ROOT_DEV="${arg#root=}"
                ;;
        esac
    done
    if [ -z "$ROOT_DEV" ] || [ ! -b "$ROOT_DEV" ]; then
        echo "error: could not find root device from cmdline" >&2
        return 1
    fi
}

list_snapshots() {
    find_root
    local mnt=$(mktemp -d)
    mount -o subvolid=5 "$ROOT_DEV" "$mnt" 2>/dev/null || {
        echo "error: could not mount btrfs" >&2
        rm -rf "$mnt"
        return 1
    }

    echo "snapshots on $(basename "$ROOT_DEV"):"
    echo "---"
    btrfs subvolume list -o "$mnt" 2>/dev/null | grep -v "^ID 5" | awk '{print "  " $NF}'

    umount "$mnt"
    rm -rf "$mnt"
}

select_snapshot() {
    find_root
    local mnt=$(mktemp -d)
    mount -o subvolid=5 "$ROOT_DEV" "$mnt" 2>/dev/null || {
        echo "error: could not mount btrfs" >&2
        rm -rf "$mnt"
        return 1
    }

    local subvols=()
    while IFS= read -r line; do
        subvols+=("$(echo "$line" | awk '{print $NF}')")
    done < <(btrfs subvolume list -o "$mnt" 2>/dev/null | grep -v "^ID 5")

    umount "$mnt"
    rm -rf "$mnt"

    if [ ${#subvols[@]} -eq 0 ]; then
        echo "no snapshots found"
        return 1
    fi

    echo "select a snapshot:"
    for i in "${!subvols[@]}"; do
        printf "  [%d] %s\n" $((i + 1)) "${subvols[$i]}"
    done
    echo ""
    printf "enter choice [1-%d]: " "${#subvols[@]}"
    local choice
    read -r choice

    if [ "$choice" -gt 0 ] 2>/dev/null && [ "$choice" -le "${#subvols[@]}" ]; then
        local selected="${subvols[$((choice - 1))]}"
        echo "$selected"
    fi
}

boot_snapshot() {
    local snapshot="$1"
    if [ -z "$snapshot" ]; then
        snapshot=$(select_snapshot)
    fi
    if [ -z "$snapshot" ]; then
        echo "no snapshot selected"
        return 1
    fi

    echo "setting next boot to snapshot: $snapshot"

    # write snapshot info for the bootloader/initramfs
    mkdir -p "$BOOT_DIR"
    echo "$snapshot" > "$BOOT_DIR/next_snapshot"
    echo "  wrote $BOOT_DIR/next_snapshot"
    echo "  reboot to boot from this snapshot"
    echo ""
    echo "  to cancel: rm -f $BOOT_DIR/next_snapshot"
}

BOOT_DIR="/boot/mochiboot"
COUNTER_FILE="$BOOT_DIR/boot_counter"

# EFI variable path (mochiboot GUID: 6d6f6368-6962-6f6f-7400-000000000000)
MOCHIBOOT_GUID="6d6f6368-6962-6f6f-7400-000000000000"
EFIVARFS="/sys/firmware/efi/efivars"
BOOT_COUNT_VAR="MochiBootBootCount-$MOCHIBOOT_GUID"
FORCE_RECOVERY_VAR="MochiBootForceRecovery-$MOCHIBOOT_GUID"

# EFI variable attributes (BS|RT = 0x07)
ATTRS="\x07\x00\x00\x00"

reset_efi_counter() {
    local efivar="$EFIVARFS/$BOOT_COUNT_VAR"
    if [ -f "$efivar" ]; then
        # attributes (4 bytes LE) + counter value (4 bytes LE) = 8 bytes
        printf '%b\x00\x00\x00\x00' "$ATTRS" > "$efivar"
        echo "  boot counter reset (efivar)"
    fi
}

set_force_recovery() {
    local efivar="$EFIVARFS/$FORCE_RECOVERY_VAR"
    printf '%b\x01\x00\x00\x00' "$ATTRS" > "$efivar"
    echo "  force recovery on next boot (efivar)"
}

get_efi_counter() {
    if [ -f "$EFIVARFS/$BOOT_COUNT_VAR" ]; then
        local data
        data=$(cat "$EFIVARFS/$BOOT_COUNT_VAR" 2>/dev/null) || return 1
        # skip first 4 bytes (attrs), read 4 bytes LE
        printf '%d' "'${data:4:1}" 2>/dev/null
    fi
}

mark_good() {
    rm -f "$COUNTER_FILE"
    rm -f "$BOOT_DIR/next_snapshot"
    if [ -d "$EFIVARFS" ]; then
        reset_efi_counter
    fi
    echo "  boot marked successful"
}

check_counter() {
    local max="${1:-3}"
    local count=0
    # check efivar first, fall back to file
    if [ -f "$EFIVARFS/$BOOT_COUNT_VAR" ]; then
        count=$(get_efi_counter) || count=0
    elif [ -f "$COUNTER_FILE" ]; then
        count=$(cat "$COUNTER_FILE" 2>/dev/null || echo 0)
    fi
    if [ "$count" -ge "$max" ]; then
        echo "recovery"
        return 0
    fi
    echo "ok"
    return 0
}

cmd="${1:-list}"
case "$cmd" in
    list|l)
        list_snapshots
        ;;
    select|s)
        select_snapshot
        ;;
    boot|b)
        shift
        boot_snapshot "$@"
        ;;
    mark-good|good)
        mark_good
        ;;
    check)
        shift
        check_counter "$@"
        ;;
    inc|increment)
        if [ -d "$EFIVARFS" ]; then
            local count=$(get_efi_counter)
            count=$((count + 1))
            printf '%b%s' "$ATTRS" "$(printf '\\x%02x' "$count")\x00\x00\x00" > "$EFIVARFS/$BOOT_COUNT_VAR"
            echo "  boot count: $count (efivar)"
        else
            increment_counter
        fi
        ;;
    force-recovery|fr)
        set_force_recovery
        ;;
    *)
        echo "usage: mochi-snapshot {list|select|boot|mark-good|check|inc|force-recovery}"
        echo ""
        echo "  list              - list all btrfs snapshots"
        echo "  select            - interactively pick a snapshot"
        echo "  boot <path>       - set a snapshot to boot next"
        echo "  mark-good         - mark current boot as successful"
        echo "  check [max]       - check if boot count exceeds max"
        echo "  inc               - increment boot counter"
        echo "  force-recovery    - force recovery entry on next boot"
        exit 1
        ;;
esac
